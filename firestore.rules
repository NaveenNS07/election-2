rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only authenticated users can read or write to their own settings and progress
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Public data like myths or journey metadata (if any)
    match /public_data/{document=**} {
      allow read: if true;
      allow write: if false; // Only admin via console
    }
  }
}
